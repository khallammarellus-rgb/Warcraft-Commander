<?xml version='1.0' encoding='utf-8'?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Campaign Package (template)</name>
    <description>Copy the Campaign Package folder into a theater campaign file (e.g. kalimdor.kml), or run python3 scripts/sync_campaign_tier_lod.py to migrate all theater shells automatically.</description>
    <Folder>
      <name>Campaign Package</name>
      <description>Faction and tier folders for this theater. Place each unit in one tier folder under red-cell or blue-cell. White-cell uses discovered folders for manual reveal.</description>
      <open>1</open>
      <Folder>
        <name>red-cell</name>
        <description>Red force — place friendly units and graphics here.</description>
        <open>1</open>
        <Folder>
          <name>Strategic</name>
          <description>HQ, regiment, division, army — visible at planet scale (~6000–3000 mi eye altitude).</description>
          <open>1</open>
        </Folder>
        <Folder>
          <name>Operational</name>
          <description>Platoon through battalion — visible at continent scale (~2000–1000 mi).</description>
          <open>1</open>
        </Folder>
        <Folder>
          <name>Tactical</name>
          <description>Squad and below — visible below ~500 mi eye altitude.</description>
          <open>1</open>
        </Folder>
      </Folder>
      <Folder>
        <name>blue-cell</name>
        <description>Blue force — place friendly units and graphics here.</description>
        <open>1</open>
        <Folder>
          <name>Strategic</name>
          <description>HQ, regiment, division, army — visible at planet scale (~6000–3000 mi eye altitude).</description>
          <open>1</open>
        </Folder>
        <Folder>
          <name>Operational</name>
          <description>Platoon through battalion — visible at continent scale (~2000–1000 mi).</description>
          <open>1</open>
        </Folder>
        <Folder>
          <name>Tactical</name>
          <description>Squad and below — visible below ~500 mi eye altitude.</description>
          <open>1</open>
        </Folder>
      </Folder>
      <Folder>
        <name>white-cell</name>
        <description>White cell / referee — adjudication markers and discovered enemy.</description>
        <open>1</open>
        <Folder>
          <name>Strategic</name>
          <description>HQ, regiment, division, army — visible at planet scale (~6000–3000 mi eye altitude).</description>
          <open>1</open>
        </Folder>
        <Folder>
          <name>Operational</name>
          <description>Platoon through battalion — visible at continent scale (~2000–1000 mi).</description>
          <open>1</open>
        </Folder>
        <Folder>
          <name>Tactical</name>
          <description>Squad and below — visible below ~500 mi eye altitude.</description>
          <open>1</open>
        </Folder>
        <Folder>
          <name>redcell-discovered</name>
          <description>Enemy markers red-cell is allowed to see (referee reveal).</description>
          <open>1</open>
        </Folder>
        <Folder>
          <name>bluecell-discovered</name>
          <description>Enemy markers blue-cell is allowed to see (referee reveal).</description>
          <open>1</open>
        </Folder>
      </Folder>
    </Folder>
  </Document>
</kml>