          <open>1</open>
          <description>Squad and below — visible below ~500 mi eye altitude.</description>
          <Folder>
            <name>Units</name>
            <description>WOW-SETUP-SCAFFOLD — Place tactical-tier unit placemarks here.</description>
          </Folder>
          <Folder>
            <name>Operational Graphics</name>
            <description>WOW-SETUP-SCAFFOLD — Boundaries, axes, phase lines, and other graphics (Tactical).</description>
